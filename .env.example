# ─── Flask ─────────────────────────────────────────────────────────
# Required in production: use a long random string.
SECRET_KEY=change-me-to-a-long-random-secret

# Set to `production` on Railway / live servers (disables Flask debug behaviour).
FLASK_ENV=development

# ─── Database ───────────────────────────────────────────────────────
# Local default is SQLite. On Railway, Postgres provides DATABASE_URL automatically.
DATABASE_URL=sqlite:///site.db

# Optional: max upload size in bytes (default 16 MB).
# MAX_CONTENT_LENGTH=16777216

# ─── First admin user (used only when the database has no users yet) ─
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# ─── Media uploads (recommended for Railway — disk is ephemeral) ─────
# Option A: single URL (Cloudinary dashboard → API Environment variable)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Option B: separate variables
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ─── Newsletter (Brevo) ──────────────────────────────────────────────
# Leave blank or use placeholders to skip API calls in local dev.
BREVO_API_KEY=
BREVO_LIST_ID=

# ─── reCAPTCHA v3 ────────────────────────────────────────────────────
# Site key is exposed to the browser; secret stays on the server only.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─── AI writing tools (admin post editor) — OpenRouter ───────────────
# https://openrouter.ai/keys — create a key and pick any model id from their site.
OPENROUTER_API_KEY=

# Model slug on OpenRouter (examples: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, google/gemini-flash-1.5)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Usually leave default. Override only if OpenRouter changes their API path.
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Optional but recommended by OpenRouter (used in API headers).
# OPENROUTER_HTTP_REFERER=https://your-site.com
# OPENROUTER_APP_TITLE=My Law Blog
