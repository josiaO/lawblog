# Copy to `.env` for local use. Never commit real secrets.
# This file is safe to commit; use placeholders only here.

# ─── Flask ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret

# Use `production` on Railway / live hosts (disables debug-style behaviour).
FLASK_ENV=development

# ─── Database ───────────────────────────────────────────────────────
DATABASE_URL=sqlite:///site.db

# Optional: max upload size in bytes (default 16 MB).
# MAX_CONTENT_LENGTH=16777216

# ─── Public URL (required for email links when sending outside a web request) ─
# Set to your live site with no trailing slash. Used for new-post emails and assets.
# PUBLIC_BASE_URL=https://your-domain.com

# ─── First admin (only when the database has no users yet) ───────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# ─── Cloudinary (recommended on Railway — disk is ephemeral) ─────────
# Option A: dashboard "API Environment variable" (single line)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Option B: separate variables
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ─── Brevo (newsletter list + transactional email) ───────────────────
# API key: Brevo → SMTP & API → API keys. Do not commit real keys.
BREVO_API_KEY=
# Contacts list ID (Contacts → Lists → ID in URL or list settings).
BREVO_LIST_ID=
# Sender must be a verified sender/domain in Brevo (Senders & IP).
BREVO_SENDER_EMAIL=noreply@your-verified-domain.com
# Optional display name for the From header (defaults to site name in Admin → Settings).
# BREVO_SENDER_NAME=Counsel & Craft

# Set to 0 to stop emailing all subscribers when a post is first published.
# BREVO_NOTIFY_NEW_POST=1

# ─── reCAPTCHA v3 ────────────────────────────────────────────────────
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─── Admin post editor — AI rewrite (auto fallback chain) ─────────────
# Set any combination of keys. Order: Gemini → xAI Grok → OpenRouter.
# Missing keys are skipped with no error; if one provider fails (quota, etc.), the next is tried.
#
# 1) Google Gemini (direct API, free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GOOGLE_API_KEY=   # alias for GEMINI_API_KEY
# GEMINI_MODEL=gemini-2.0-flash
#
# 2) xAI Grok
# XAI_API_KEY=
# XAI_MODEL=grok-2-latest
# XAI_API_BASE=https://api.x.ai/v1
#
# 3) OpenRouter — default model is Google Gemini via OpenRouter if OPENROUTER_MODEL is unset
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your-site.com
# OPENROUTER_APP_TITLE=My Law Blog

# Smaller = faster AI requests (default 120000). Increase for very long drafts.
# AI_MAX_INPUT_CHARS=120000

# ─── Brevo: if contacts appear but no mail arrives ───────────────────
# Subscribers sync via the Contacts API; welcome mail uses Transactional API.
# BREVO_SENDER_EMAIL must be an address on a domain YOU control and have
# verified in Brevo (SMTP & API → Senders, domains & dedicated IPs).
# Addresses like noreply@*.railway.app or @herokuapp.com cannot be verified.
# When creating the API key, enable permission to send transactional emails.
# Check delivery in Brevo → Transactional → Logs. Ask users to check spam.
# Optional explicit Reply-To (else Site Settings → Email is used):
# BREVO_REPLY_TO_EMAIL=you@yourdomain.com