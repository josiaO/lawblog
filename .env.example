# Copy to `.env` for local use. Never commit real secrets.
# This file is safe to commit; use placeholders only here.

# ─── Flask ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret

# Use `production` on Railway / live hosts (disables debug-style behaviour).
FLASK_ENV=development

# ─── Database ───────────────────────────────────────────────────────
DATABASE_URL=sqlite:///site.db

# Optional: max upload size in bytes (default 16 MB).
# MAX_CONTENT_LENGTH=16777216

# ─── Public URL (required for email links when sending outside a web request) ─
# Set to your live site with no trailing slash. Used for new-post emails and assets.
# PUBLIC_BASE_URL=https://your-domain.com

# ─── First admin (only when the database has no users yet) ───────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# ─── Cloudinary (recommended on Railway — disk is ephemeral) ─────────
# Option A: dashboard "API Environment variable" (single line)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Option B: separate variables
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ─── Brevo (newsletter list + transactional email) ───────────────────
# API key: Brevo → SMTP & API → API keys. Do not commit real keys.
BREVO_API_KEY=
# Contacts list ID (Contacts → Lists → ID in URL or list settings).
BREVO_LIST_ID=
# Sender must be a verified sender/domain in Brevo (Senders & IP).
BREVO_SENDER_EMAIL=noreply@your-verified-domain.com
# Optional display name for the From header (defaults to site name in Admin → Settings).
# BREVO_SENDER_NAME=Counsel & Craft

# Set to 0 to stop emailing all subscribers when a post is first published.
# BREVO_NOTIFY_NEW_POST=1

# ─── reCAPTCHA v3 ────────────────────────────────────────────────────
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─── OpenRouter (admin AI tools in post editor) ──────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your-site.com
# OPENROUTER_APP_TITLE=My Law Blog
