# Copy to `.env` for local use. Never commit real secrets.
# This file is safe to commit; use placeholders only here.

# ─── Flask (required in production) ─────────────────────────────────
# Production: must be 32+ random characters. The app refuses to start without it when
# FLASK_ENV=production, ENV=production, or RAILWAY_ENVIRONMENT=production.
# Flask-WTF CSRF is enabled; tokens are signed with SECRET_KEY. JSON POSTs must send header X-CSRFToken
# (see meta name="csrf-token" in public/admin base templates).
SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars

# Use `production` on Railway / live hosts (disables Flask debug behaviour).
FLASK_ENV=development

# ─── Database ───────────────────────────────────────────────────────
DATABASE_URL=sqlite:///site.db

# PostgreSQL only (ignored for SQLite): SQLAlchemy pool tuning
# SQLALCHEMY_POOL_SIZE=10
# SQLALCHEMY_MAX_OVERFLOW=20
# SQLALCHEMY_POOL_RECYCLE=3600
# Aliases (same meaning): DB_POOL_SIZE, DB_POOL_MAX_OVERFLOW, DB_POOL_RECYCLE

# Optional: max upload size in bytes (default 16 MB).
# MAX_CONTENT_LENGTH=16777216

# ─── Public site URL (required for email links in background workers) ─
PUBLIC_BASE_URL=https://your-domain.com
# SITE_URL=https://your-domain.com

# ─── First admin (only when the database has no users yet) ───────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# ─── Cloudinary (recommended on Railway — disk is ephemeral) ─────────
# Option A: dashboard "API Environment variable" (single line)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Option B: separate variables
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ─── Brevo (newsletter list + transactional email) ───────────────────
BREVO_API_KEY=
BREVO_LIST_ID=
BREVO_SENDER_EMAIL=noreply@your-verified-domain.com
BREVO_SENDER_NAME=Counsel & Craft
BREVO_NOTIFY_NEW_POST=1
BREVO_REPLY_TO_EMAIL=you@yourdomain.com

# ─── reCAPTCHA v3 ────────────────────────────────────────────────────
# Use both together. Secret alone breaks newsletter subscribe (no token from the browser).
# Optional: minimum v3 score (0–1). Default 0.3 is kinder to Edge / strict privacy than 0.5.
# RECAPTCHA_MIN_SCORE=0.3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─── Admin post editor — AI (Groq first, then OpenRouter; OpenAI SDK) ─
# Set at least one key. Both may be set; the app tries Groq, then OpenRouter on failure.
GROQ_API_KEY=
GROQ_MODEL_PRESET=balanced
GROQ_MODEL=llama-3.3-70b-versatile

# Seconds (5–600). Fallback when the more specific vars below are unset.
# AI_HTTP_TIMEOUT=90
# Help-assistant AI expansion (defaults: 60s help, falls back to AI_HTTP_TIMEOUT logic via _openai_http_timeout(60)).
# AI_HTTP_TIMEOUT_HELP=60
# Post editor AI rewriting (defaults: 120s).
# AI_HTTP_TIMEOUT_EDITOR=120

OPENROUTER_API_KEY=
OPENROUTER_MODEL_PRESET=auto_free
OPENROUTER_MODEL=openrouter/free
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://your-site.com
OPENROUTER_APP_TITLE=My Lawlog

AI_MAX_INPUT_CHARS=120000

# Optional: cap HTML size before bleach sanitization on public post render (default 2000000).
# BLEACH_MAX_INPUT_CHARS=2000000

# ─── Brevo notes ─────────────────────────────────────────────────────
# Subscribers sync via Contacts API; transactional mail needs a verified BREVO_SENDER_EMAIL.
# Check delivery in Brevo → Transactional → Logs.
